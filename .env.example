# ── Required ──────────────────────────────────────────────────────────────────
USER_EMAIL=your.gmail@gmail.com           # Gmail account to send from and monitor
ANTHROPIC_API_KEY=your_anthropic_api_key
TAVILY_API_KEY=your_tavily_api_key

# ── Sender identity (shown in cold emails) ────────────────────────────────────
SENDER_NAME=徐廷宇
SENDER_TITLE=營運經理
SENDER_PHONE=                             # Optional — leave blank to hide phone line
PDF_LINK=https://drive.google.com/file/d/1J77LPg8EnuTR1dohNaTmlsElUal4Hzpv/view?usp=sharing

# ── Google OAuth (set paths, place file at credentials/oauth_credentials.json) ─
GOOGLE_CREDENTIALS_FILE=credentials/oauth_credentials.json
GOOGLE_TOKEN_FILE=credentials/token.json

# ── Auto-configured by setup.py (do not fill manually) ───────────────────────
SPREADSHEET_ID=

# ── Sheet / scheduling config (defaults are fine) ────────────────────────────
LEADS_SHEET_NAME=YIT_Lead_Gen_Leads
